<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#142050"
    tools:context=".ui.RecuperacionDeCuenta.RestablecerContrasena">

    <ImageView
        android:layout_width="150dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:src="@drawable/logo" />

    <LinearLayout
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="20dp"
        >

        <!-- Banner de Error -->
        <TextView
            android:id="@+id/tvErrorBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#FFEBEE"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="#C62828"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:drawableStart="@android:drawable/stat_notify_error"
            android:drawablePadding="8dp" />

        <TextView
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva contraseña"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimario"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingresa los datos enviados a tu correo"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:textColor="#959595"
            android:layout_marginBottom="20dp"
            />

        <!-- Campo UID -->
        <EditText
            android:id="@+id/etUid"
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="UID (ej. OTI)"
            android:padding="10dp"
            android:layout_marginBottom="10dp"
            android:textColor="@color/black"
            android:background="@drawable/input_recuperrar"
            />

        <!-- Campo Token -->
        <EditText
            android:id="@+id/etToken"
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Token de seguridad"
            android:padding="10dp"
            android:layout_marginBottom="10dp"
            android:textColor="@color/black"
            android:background="@drawable/input_recuperrar"
            />

        <!-- Nueva Contraseña -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/etNuevaPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Nueva contraseña (mín. 8 carac.)"
                android:padding="10dp"
                android:paddingEnd="45dp"
                android:inputType="textPassword"
                android:textColor="@color/black"
                android:background="@drawable/input_recuperrar"
                />

            <ImageView
                android:id="@+id/ivShowNewPassword"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:src="@drawable/baseline_remove_red_eye_24"
                android:contentDescription="Ver contraseña"
                app:tint="#64748B" />
        </RelativeLayout>

        <!-- Confirmar Contraseña -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/etConfirmarPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Confirma tu contraseña"
                android:padding="10dp"
                android:paddingEnd="45dp"
                android:inputType="textPassword"
                android:textColor="@color/black"
                android:background="@drawable/input_recuperrar"
                />

            <ImageView
                android:id="@+id/ivShowConfirmPasswordReset"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:src="@drawable/baseline_remove_red_eye_24"
                android:contentDescription="Ver contraseña"
                app:tint="#64748B" />
        </RelativeLayout>

        <Button
            android:id="@+id/btnNuevacontraseña"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="RESTABLECER AHORA"
            android:backgroundTint="#23B1FD"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            />
    </LinearLayout>
</LinearLayout>
