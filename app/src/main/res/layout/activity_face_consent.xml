<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#182052"
    android:padding="24dp">

    <ImageView
        android:id="@+id/imgFace"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_face_unlock"
        android:contentDescription="@string/face_consent_icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="36dp" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Activa inicio de sesión facial"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/imgFace"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardConsent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="18dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#35D6BE">

            <TextView
                android:id="@+id/tvBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Usaremos tu reconocimiento facial para facilitar el inicio de sesión en este dispositivo. Si lo autorizas, tu plantilla biométrica también podrá asociarse a tu cuenta para recuperación en cambio de dispositivo o reinstalación."
                android:textColor="#0D1B4C"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <TextView
                android:id="@+id/tvLegal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Tu rostro es un dato biométrico y sensible. Su uso es opcional. Puedes seguir usando contraseña y revocar esta autorización más adelante."
                android:textColor="#0D1B4C"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp" />

            <CheckBox
                android:id="@+id/cbConsent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="He leído y autorizo de forma previa, expresa e informada el tratamiento de mis datos biométricos para autenticación, conforme a la política de tratamiento de datos personales."
                android:textColor="#0D1B4C"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPolicy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ver política de tratamiento de datos"
                android:textColor="#0D1B4C"
                android:textStyle="bold"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnAccept"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Aceptar y registrar rostro"
        android:enabled="false"
        android:textColor="@android:color/white"
        android:backgroundTint="#0D1B4C"
        app:layout_constraintTop_toBottomOf="@id/cardConsent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnSkip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="No por ahora"
        android:textColor="#0D1B4C"
        android:backgroundTint="#D8F0F0"
        app:layout_constraintTop_toBottomOf="@id/btnAccept"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvRights"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Podrás conocer, actualizar, rectificar o revocar tu autorización a través de los canales de atención definidos en la política de tratamiento de datos."
        android:textColor="#C9D2F0"
        android:textSize="12sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/btnSkip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>