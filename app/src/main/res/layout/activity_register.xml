<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimario"
    android:orientation="vertical"
    tools:context=".ui.Autenticacion.Register">

    <!-- Sección Superior con Logo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.6"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/logo"
            android:contentDescription="Logo Fisikapp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Fisikapp"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tarjeta de Registro -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.6"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="-20dp"
        app:cardBackgroundColor="#3EDBA0"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Banner de Error -->
                <TextView
                    android:id="@+id/tvErrorBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="#FFEBEE"
                    android:gravity="center"
                    android:padding="12dp"
                    android:textColor="#C62828"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:drawableStart="@android:drawable/stat_notify_error"
                    android:drawablePadding="8dp" />

                <!-- Campo Nombre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre completo"
                    android:textColor="#064E3B"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/edtNombrecompleto"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edittext_redondo"
                    android:backgroundTint="@color/white"
                    android:hint="Ej: Cristian David"
                    android:textColorHint="#94A3B8"
                    android:textColor="@color/black"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp" />

                <!-- Campo Identificación -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Número de identificación"
                    android:textColor="#064E3B"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/edtIdentificacion"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edittext_redondo"
                    android:backgroundTint="@color/white"
                    android:hint="1000..."
                    android:textColorHint="#94A3B8"
                    android:inputType="number"
                    android:textColor="@color/black"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp" />

                <!-- Campo Fecha Nacimiento -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Fecha de nacimiento"
                    android:textColor="#064E3B"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/edtFechaNacimiento"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edittext_redondo"
                    android:backgroundTint="@color/white"
                    android:hint="AAAA-MM-DD"
                    android:textColorHint="#94A3B8"
                    android:inputType="date"
                    android:textColor="@color/black"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp" />

                <!-- Campo Institución -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Institución / Colegio"
                    android:textColor="#064E3B"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/edtInstitucion"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edittext_redondo"
                    android:backgroundTint="@color/white"
                    android:hint="SENA"
                    android:textColorHint="#94A3B8"
                    android:textColor="@color/black"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp" />

                <!-- Campo Correo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Correo electrónico"
                    android:textColor="#064E3B"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/editTextText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edittext_redondo"
                    android:backgroundTint="@color/white"
                    android:hint="correo@ejemplo.com"
                    android:textColorHint="#94A3B8"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/black"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp" />

                <!-- Campo Contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Contraseña"
                    android:textColor="#064E3B"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <EditText
                        android:id="@+id/editText"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/edittext_redondo"
                        android:backgroundTint="@color/white"
                        android:drawableStart="@drawable/baseline_lock_24"
                        android:drawablePadding="12dp"
                        android:hint="........."
                        android:textColorHint="#94A3B8"
                        android:inputType="textPassword"
                        android:textColor="@color/black"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/ivShowPasswordReg"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/baseline_remove_red_eye_24"
                        android:contentDescription="Ver contraseña"
                        app:tint="#64748B" />
                </RelativeLayout>

                <!-- Confirmar Contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Confirmar contraseña"
                    android:textColor="#064E3B"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <EditText
                        android:id="@+id/edtConfirmarcont"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/edittext_redondo"
                        android:backgroundTint="@color/white"
                        android:drawableStart="@drawable/baseline_lock_24"
                        android:drawablePadding="12dp"
                        android:hint="........."
                        android:textColorHint="#94A3B8"
                        android:inputType="textPassword"
                        android:textColor="@color/black"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/ivShowConfirmPassword"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/baseline_remove_red_eye_24"
                        android:contentDescription="Ver contraseña"
                        app:tint="#64748B" />
                </RelativeLayout>

                <!-- Botón Crear Cuenta -->
                <Button
                    android:id="@+id/btnCrearCuenta"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="@color/colorPrimario"
                    android:text="Crear cuenta"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:cornerRadius="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="40dp" />

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- Footer -->
    <TextView
        android:id="@+id/btnYaTienesCuenta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="24dp"
        android:text="¿Ya tienes cuenta? Inicia sesión"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
