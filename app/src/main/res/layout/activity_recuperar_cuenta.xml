<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimario"
    android:orientation="vertical"
    tools:context=".ui.RecuperacionDeCuenta.RecuperarCuenta">

    <!-- Sección Superior: Logo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/logo"
            android:contentDescription="Logo Fisikapp" />
    </LinearLayout>

    <!-- Tarjeta Blanca Flotante -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        android:layout_marginBottom="-32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Banner de Error -->
            <TextView
                android:id="@+id/tvErrorBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#FFEBEE"
                android:gravity="center"
                android:padding="12dp"
                android:textColor="#C62828"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:drawableStart="@android:drawable/stat_notify_error"
                android:drawablePadding="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recupera tu cuenta"
                android:textColor="@color/colorPrimario"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Introduce tu dirección de correo electrónico y te enviaremos un enlace para restablecer tu contraseña."
                android:textColor="#64748B"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />

            <!-- Campo Correo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Correo electrónico"
                android:textColor="#64748B"
                android:textStyle="bold"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etEmailRecuperar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edittext_redondo"
                android:backgroundTint="#DEDDDD"
                android:drawableStart="@drawable/ci_email"
                android:drawablePadding="12dp"
                android:hint="tu.correo@ejemplo.com"
                android:inputType="textEmailAddress"
                android:textColor="@color/black"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                />

            <!-- Botón Siguiente -->
            <Button
                android:id="@+id/btnSRestableser"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/colorPrimario"
                android:text="Siguiente"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="12dp" />

            <!-- Regresar -->
            <TextView
                android:id="@+id/btnRegresarsesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:text="Regresar al inicio de sesión"
                android:textColor="@color/colorSecundario"
                android:textStyle="bold"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
