<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimario"
    android:orientation="vertical"
    tools:context=".ui.MonitorDeAprendizajeEstudiante.ConceptosBasicos">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#002B7F">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/iconoretroceder"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiro parabólico"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Conceptos"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="#4A5FE7"
            android:textSize="16sp"
            android:padding="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Fórmulas"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="#808080"
            android:textSize="16sp"
            android:padding="16dp"/>
    </LinearLayout>

    <!-- Línea indicador -->
    <View
        android:layout_width="120dp"
        android:layout_height="3dp"
        android:layout_marginStart="40dp"
        android:background="#4A5FE7"/>

    <!-- Contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@color/white">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conceptos clave"
                android:textStyle="bold"
                android:textSize="28sp"
                android:textColor="#000000"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="El tiro parabólico es un movimiento en dos dimensiones donde un objeto es lanzado con un ángulo respecto a la horizontal."
                android:textSize="16sp"
                android:textColor="#444444"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• En el eje horizontal (x) el movimiento es MRU (velocidad constante)."
                android:textSize="16sp"
                android:textColor="#444444"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• En el eje vertical (y) el movimiento es MRUA (aceleración = -g)."
                android:textSize="16sp"
                android:textColor="#444444"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• La trayectoria que describe el objeto es una parábola."
                android:textSize="16sp"
                android:textColor="#444444"
                android:layout_marginTop="10dp"/>

            <!-- Card imagen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Componentes del movimiento"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#000000"
                    android:layout_gravity="center_horizontal"/>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="16dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/parabolico"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="El uso de vectores permite representar movimientos en diferentes direcciones y hacer operaciones matemáticas para calcular la trayectoria final de un objeto en movimiento."
                android:textSize="16sp"
                android:textColor="#444444"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"/>

            <!-- Botón para ir a Fórmulas -->
            <Button
                android:id="@+id/btnVerFormulas"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Ver fórmulas →"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#000000"
                android:backgroundTint="#FFC107"
                android:layout_marginTop="24dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Omitido por brevedad -->
</LinearLayout>
