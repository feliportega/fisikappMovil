<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris"
    android:orientation="vertical"
    tools:context=".Login">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="255dp"
        android:background="#142050"
        android:orientation="vertical">

        <ImageView
            android:layout_width="200dp"
            android:layout_height="135dp"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="aprende y construye laboratorios interactivos"
            android:textColor="#D7D7D7"
            android:textSize="16sp" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="500dp"
        android:orientation="vertical"
        android:background="@color/white"
        android:layout_gravity="center"
        >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Iniciar sesion"
            android:textSize="25sp"
            android:layout_margin="15dp"
            android:textStyle="bold"
            android:textColor="#2E2E2E"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Correo electronico"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#5F5F5F"
            android:layout_marginLeft="18dp"
            />
        <EditText
            android:background="@drawable/desing"
            android:padding="10dp"
            android:id="@+id/editTextText"
            android:layout_width="310dp"
            android:layout_height="wrap_content"
            android:ems="10"
            android:inputType="text"
            android:drawablePadding="10dp"
            android:drawableLeft="@drawable/ci_email"
            android:layout_gravity="center"
            android:hint="email" />
        <TextView
            android:layout_marginTop="13dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contraseña"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#5F5F5F"
            android:layout_marginLeft="18dp"
            />

        <EditText
            android:background="@drawable/desing"
            android:padding="10dp"
            android:id="@+id/editText"
            android:layout_width="310dp"
            android:layout_height="wrap_content"
            android:ems="10"
            android:inputType="text"
            android:drawablePadding="10dp"
            android:drawableLeft="@drawable/baseline_lock_24"
            android:layout_gravity="center"
            android:hint="contraseña" />
        <Button
            android:id="@+id/btnRecuperarc"
            android:layout_marginTop="0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿olvidas tu contraseña?"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#404040"
            android:layout_gravity="right"
            android:layout_marginRight="21dp"
            android:backgroundTint="@color/white"
            />
        <Button
            android:id="@+id/btnIniciarsesion"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:text="Iniciar sesión"
            android:layout_gravity="center"
            android:layout_marginTop="0dp"
            android:backgroundTint="#3A46B6"
            />
        <Button
            android:id="@+id/btnResgistrarse"
            android:layout_marginTop="17dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿no tines cuenta?        REGISTRATE   "
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#343434"
            android:layout_gravity="right"
            android:layout_marginRight="29dp"
            android:backgroundTint="@color/white"
            />

        <Button
            android:backgroundTint="#DFEBEF"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:text="Continuar con Google"
            android:layout_gravity="center"
            android:layout_marginTop="60dp"
            android:textColor="#0756F4"
            />


    </LinearLayout>

</LinearLayout>