<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA"
    tools:context=".ui.MonitorDeAprendizajeEstudiante.PracticaConceptos">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0C1446"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Práctica de conceptos"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Objetivo General:"
                android:textStyle="bold"
                android:textColor="#000000" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Comprender el comportamiento del tiro parabólico observando la trayectoria de un objeto lanzado..."
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Objetivos Específicos:"
                android:textStyle="bold"
                android:textColor="#000000" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Identificar la trayectoria parabólica.\n• Observar cómo influye la velocidad inicial.\n• Relacionar el experimento con conceptos físicos."
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Materiales:"
                android:textStyle="bold"
                android:textColor="#3B82F6" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 1 pelota pequeña (puede ser de ping-pong, tenis o una bola de papel).\n• 1 metro o cinta métrica.\n• 1 celular para grabar (opcional).\n• 1 cuaderno para registrar datos.  \n• Cinta o tiza para marcar el suelo."
                android:textColor="#3B82F6"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Procedimiento:"
                android:textStyle="bold"
                android:textColor="#000000" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Ingresa a la sección de simulación.\n2. Ajusta los parámetros necesarios.\n3. Observa la trayectoria en tu entorno." />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSiguienteEtapa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="20dp"
        android:text="Siguiente etapa"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2ECC71" />
</LinearLayout>
