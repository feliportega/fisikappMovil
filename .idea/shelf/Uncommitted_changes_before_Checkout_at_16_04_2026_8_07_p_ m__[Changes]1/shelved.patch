+    private void cargarContenidoDeAPI() {
+        RetrofitClient.getApiService().getConceptos().enqueue(new Callback<List<Contenido>>() {
+            @Override
+            public void onResponse(Call<List<Contenido>> call, Response<List<Contenido>> response) {
+                if (response.isSuccessful() && response.body() != null && !response.body().isEmpty()) {
+                    // Tomamos el primer contenido de la lista para mostrar
+                    Contenido contenido = response.body().get(0);
+                    
+                    // Actualizamos la interfaz con los datos reales de Django
+                    if (tvTitulo != null) tvTitulo.setText(contenido.getTitulo());
+                    if (tvDescripcion != null) tvDescripcion.setText(contenido.getDescripcion());
+                    
+                    Log.d("API_SUCCESS", "Datos cargados: " + contenido.getTitulo());
+                } else {
+                    Log.e("API_ERROR", "Error en la respuesta: " + response.code());
+                    Toast.makeText(ConceptosBasicos.this, "No se pudo cargar el contenido", Toast.LENGTH_SHORT).show();
+                }
+            }
+
+            @Override
+            public void onFailure(Call<List<Contenido>> call, Throwable t) {
+                Log.e("API_FAILURE", "Fallo de conexión: " + t.getMessage());
+                Toast.makeText(ConceptosBasicos.this, "Error de conexión con el servidor", Toast.LENGTH_SHORT).show();
+            }
+        });
+    }
